{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "out-dist/types/**/*.ts",
    "out-dist/dev/types/**/*.ts",
    "out/types/**/*.ts",
    "out/dev/types/**/*.ts",
    "out-v3/types/**/*.ts",
    "out-v3/dev/types/**/*.ts",
    "out-v4/types/**/*.ts",
    "out-v4/dev/types/**/*.ts",
    "out-v5/types/**/*.ts",
    "out-v5/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
